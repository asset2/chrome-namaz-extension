{
  "manifest_version": 3,
  "name": "Следующий намаз (Алматы)",
  "description": "Показывает время следующего намаза для Алматы на основе данных sajda.com.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Следующий намаз",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://sajda.com/*"
  ]
}
